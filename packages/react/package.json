{
  "name": "@codeai/cads-react",
  "version": "0.1.0",
  "description": "CADS React components (MUI-wrapped) and icons",
  "type": "module",
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "restricted"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest/cads.manifest.d.ts",
      "import": "./dist/manifest/cads.manifest.js"
    },
    "./icons/fonts.css": "./dist/icons/fonts.css"
  },
  "files": [
    "dist",
    "src/icons/fonts",
    "src/manifest"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@codeai/cads-variables": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.2.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}
