{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code.org/cads/visual-recipe.schema.json",
  "title": "CADS component visual recipe",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "component",
    "figma",
    "change",
    "axes",
    "geometry",
    "recipes",
    "coverage",
    "acceptedDifferences",
    "evidence"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "component": { "type": "string", "minLength": 1 },
    "figma": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fileKey",
        "publicNodeId",
        "relatedNodeIds",
        "retrievedAt",
        "designContextCaptured"
      ],
      "properties": {
        "fileKey": { "type": "string", "minLength": 1 },
        "publicNodeId": { "type": "string", "pattern": "^[0-9]+:[0-9]+$" },
        "componentKey": { "type": "string" },
        "relatedNodeIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[0-9]+:[0-9]+$" },
          "uniqueItems": true
        },
        "retrievedAt": { "type": "string", "format": "date" },
        "designContextCaptured": { "type": "boolean" }
      }
    },
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taskPath", "previousRecipe", "figmaChanges"],
      "properties": {
        "taskPath": {
          "enum": ["new", "figma-update", "code-only-fix"]
        },
        "previousRecipe": {
          "type": ["string", "null"]
        },
        "figmaChanges": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "axes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public", "designOnly", "restrictedCombinations"],
      "properties": {
        "public": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": ["string", "boolean", "number"] },
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "designOnly": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "restrictedCombinations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["when", "reason"],
            "properties": {
              "when": { "type": "object" },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "geometry": {
      "type": "object",
      "required": ["sizes", "layout", "typography", "icon"],
      "properties": {
        "sizes": { "type": "object" },
        "layout": { "type": "object" },
        "typography": { "type": "object" },
        "icon": { "type": "object" }
      }
    },
    "recipes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "when",
          "variables",
          "geometryOverrides",
          "figmaVariant",
          "notes"
        ],
        "properties": {
          "when": { "type": "object", "minProperties": 1 },
          "variables": { "type": "object", "minProperties": 1 },
          "geometryOverrides": { "type": "object" },
          "figmaVariant": { "type": "string" },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "requiredDimensions", "cases"],
      "properties": {
        "strategy": { "const": "pairwise-plus-risk" },
        "requiredDimensions": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "figmaNodeId",
              "mode",
              "props",
              "state",
              "viewport",
              "expectedGeometry",
              "expectedVariables",
              "fixturePath",
              "result",
              "mismatches"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
              },
              "figmaNodeId": {
                "type": "string",
                "pattern": "^[0-9]+:[0-9]+$"
              },
              "figmaVariant": { "type": "string" },
              "mode": { "enum": ["light", "dark"] },
              "props": { "type": "object" },
              "state": { "type": "string", "minLength": 1 },
              "viewport": {
                "type": "object",
                "additionalProperties": false,
                "required": ["width", "height", "deviceScaleFactor"],
                "properties": {
                  "width": { "type": "integer", "minimum": 1 },
                  "height": { "type": "integer", "minimum": 1 },
                  "deviceScaleFactor": { "type": "number", "minimum": 1 }
                }
              },
              "expectedGeometry": { "type": "object" },
              "expectedVariables": {
                "type": "array",
                "items": { "type": "string", "pattern": "^--" },
                "uniqueItems": true
              },
              "fixturePath": { "type": "string" },
              "referenceScreenshot": { "type": "string" },
              "browserScreenshot": { "type": "string" },
              "result": {
                "enum": ["pending", "pass", "fail", "accepted-difference"]
              },
              "mismatches": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["category", "description"],
                  "properties": {
                    "category": {
                      "enum": [
                        "geometry",
                        "typography",
                        "variable-color",
                        "state",
                        "icon",
                        "content",
                        "rendering-noise"
                      ]
                    },
                    "description": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "acceptedDifferences": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "caseIds",
          "figmaBehavior",
          "codeBehavior",
          "reason",
          "decisionSource"
        ],
        "properties": {
          "caseIds": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "figmaBehavior": { "type": "string", "minLength": 1 },
          "codeBehavior": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "decisionSource": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": [
        "apiAudit",
        "typecheck",
        "build",
        "docsBuild",
        "correctionPasses"
      ],
      "properties": {
        "apiAudit": { "type": ["object", "null"] },
        "typecheck": { "type": ["object", "null"] },
        "build": { "type": ["object", "null"] },
        "docsBuild": { "type": ["object", "null"] },
        "correctionPasses": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["caseIds", "mismatchesFound", "fixesMade", "recaptured"],
            "properties": {
              "caseIds": {
                "type": "array",
                "items": { "type": "string" }
              },
              "mismatchesFound": {
                "type": "array",
                "items": { "type": "string" }
              },
              "fixesMade": {
                "type": "array",
                "items": { "type": "string" }
              },
              "recaptured": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
